# Copy this file to .env and fill in your real keys locally.
# Do not commit .env. It is already ignored by .gitignore.

# Backend
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Frontend / Vite
# Use "/" for normal hosting. Use "/repo-name/" only when deploying a static
# build under a subpath such as GitHub Pages.
BASE_PATH=/

# Local frontend dev proxy target for /api requests.
API_PROXY_TARGET=http://localhost:8080

# Optional for local AI-only development.
# Set this when you want database-backed dream/character persistence.
DATABASE_URL=

# OpenAI powers dream chat, dream organization, and image/text recognition.
OPENAI_API_KEY=
AI_MODEL_NAME=gpt-4o

# ElevenLabs powers spoken AI replies.
ELEVENLABS_API_KEY=

# Optional local VoxCPM TTS service. Leave empty in hosted demos unless you also
# deploy the service separately.
VOXCPM_TTS_URL=http://localhost:8808/v1/tts
VOXCPM_TIMEOUT_MS=720000
